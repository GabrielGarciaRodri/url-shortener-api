{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2021",
    "declaration": false,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./",
    "incremental": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["*.ts", "prisma/prisma.service.ts", "prisma/prisma.module.ts", "url/url.service.ts", "url/url.module.ts", "url/url.controller.ts", "dto/create-url.dto.ts"],
  "exclude": ["node_modules", "dist"]
}